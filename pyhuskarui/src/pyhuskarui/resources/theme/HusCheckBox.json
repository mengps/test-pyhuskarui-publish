{
    "__style__": {
        "fontFamily": "@fontPrimaryFamily",
        "fontSize": "@fontPrimarySize",
        "colorText": "@colorTextBase",
        "colorTextDisabled": "@colorTextDisabled",
        "colorIndicator": "@colorBgBase",
        "colorIndicatorChecked": "@colorPrimary",
        "colorIndicatorCheckedHover": "@colorPrimaryHover",
        "colorIndicatorDisabled": "$alpha(@colorTextBase, 0.08)",
