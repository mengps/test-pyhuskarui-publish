{
    "__style__": {
        "fontFamily": "@fontPrimaryFamily",
        "fontSize": "@fontPrimarySize",
        "fontSizeIcon": "@fontPrimarySizeHeading5",
        "fontSizeClearIcon": "@fontPrimarySize",
        "colorIcon": "@colorTextBase",
        "colorIconDisabled": "$onBackground(@colorTextQuaternary, @colorBgBase)",
        "colorClearIcon": "$onBackground(@colorTextQuaternary, @colorBgBase)",
        "colorClearIconHover": "$onBackground(@colorTextTertiary, @colorBgBase)",
        "colorClearIconActive": "$onBackground(@colorTextPrimary, @colorBgBase)",
        "colorClearIconDisabled": "$onBackground(@colorTextQuaternary, @colorBgBase)",
        "colorText": "@colorTextBase",
        "colorTextDisabled": "@colorTextDisabled",
        "colorPlaceholderText": "@colorTextQuaternary",
        "colorPlaceholderTextDisabled": "@colorTextDisabled",
        "colorTextSelected": "@colorTextBase",
        "colorSelection": "$alpha(@colorPrimary, 0.6)",
        "colorBorder": "$onBackground(@colorBorder, @colorBgBase)",
        "colorBorderHover": "@colorPrimary",
        "colorBorderDisabled": "$onBackground(@colorBorderDisabled, @colorBgBase)",
        "colorBg": "@colorBgBase",
        "colorBgFilled": "@colorFillPrimary",
        "colorBgDisabled": "$onBackground(@colorFillPrimary, @colorBgBase)",
        "colorShadow": "@colorPrimary",
        "radiusBg": "@radiusPrimary"
    }
}
