{
    "__style__": {
        "fontFamily": "@fontPrimaryFamily",
        "fontSize": "@fontPrimarySize",
        "colorBg": "@colorBgBase",
        "colorBgDisabled": "@colorFillTertiary",
        "colorGridLine": "$onBackground(@colorFillTertiary, @colorBgBase)",
        "colorColumnTitle": "@colorTextBase",
        "colorColumnHeaderBg": "$onBackground(@colorFillSecondary, @colorBgBase)",
        "colorIcon": "@colorTextTertiary",
        "colorIconHover": "@colorPrimary",
        "colorRowTitle": "@colorTextBase",
        "colorRowHeaderBg": "$onBackground(@colorFillSecondary, @colorBgBase)",
        "colorResizeBlockBg": "$onBackground(@colorFillTertiary, @colorBgBase)",
        "colorCellBg": "@colorBgBase",
        "colorCellOddBg": "$onBackground(@colorFillTertiary, @colorBgBase)",
        "colorCellBgHover": "$onBackground(@colorFillSecondary, @colorBgBase)",
        "colorCellBgHoverChecked": "@colorPrimaryBgHover",
        "colorCellBgChecked": "@colorPrimaryBg",
        "colorCellBgDarkHoverChecked": "@colorPrimaryBase-9",
        "colorCellBgDarkChecked": "@colorPrimaryBase-10",
        "radiusBg": "@radiusPrimary"
    }
}
